{
  "name": "foyer-mono",
  "private": true,
  "description": "Foyer monorepo：当前承载 foyer CLI，后续可增加其他输出页面包。",
  "scripts": {
    "clean": "pnpm -r --if-present clean && rm -rf .flue-dist",
    "build": "pnpm -r --if-present build",
    "check": "pnpm -r --if-present check",
    "cli": "pnpm --dir packages/cli cli",
    "dev:web": "pnpm --dir apps/web-ui dev",
    "test": "pnpm -r --if-present test",
    "flue:dev": "flue dev --target node --output .flue-dist",
    "flue:run": "flue run project-init --target node --output .flue-dist",
    "prepare": "vp config"
  },
  "dependencies": {
    "@opentui/core": "^0.2.4",
    "@opentui/react": "^0.2.4",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@flue/cli": "^0.3.10",
    "@flue/sdk": "^0.3.10",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.0.9"
}
