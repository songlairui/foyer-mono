{
  "name": "entry-init-project",
  "version": "1.0.0",
  "description": "Entry 项目初始化 CLI、Effect workflow 与多宿主交付壳。",
  "main": "dist/index.js",
  "bin": {
    "entry": "dist/cli/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "cli": "tsx src/cli/index.ts",
    "flue:dev": "flue dev --target node --output .flue-dist",
    "flue:run": "flue run project-init --target node --output .flue-dist",
    "test": "vitest run tests"
  },
  "keywords": [
    "entry",
    "cli",
    "effect",
    "project-init"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "commander": "^14.0.3",
    "effect": "^3.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@flue/cli": "^0.3.10",
    "@flue/sdk": "^0.3.10",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
